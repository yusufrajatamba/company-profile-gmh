{
  "entities": {
    "setting": {
      "title": "Setting",
      "description": "Global settings for the website contents (hero, visi, misi)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "visi": { "type": "string" },
        "misi": { "type": "string" },
        "address": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" }
      },
      "required": ["id", "heroTitle", "heroSubtitle", "visi", "misi"]
    },
    "article": {
      "title": "Article",
      "description": "News, reports, or articles written by/for alumni and mission",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "author": { "type": "string" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "content", "author", "createdAt"]
    },
    "activity": {
      "title": "Activity",
      "description": "Activities or gallery photos from past events",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "date": { "type": "string", "format": "date" }
      },
      "required": ["id", "title", "imageUrl", "date"]
    },
    "misiRegistration": {
      "title": "MisiRegistration",
      "description": "Form submissions of people registering for mission programs",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "misiTitle": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "misiTitle", "fullName", "email", "phone", "status", "createdAt"]
    },
    "message": {
      "title": "Message",
      "description": "Contact form submissions from the Contact section",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "fullName", "email", "subject", "message", "createdAt"]
    }
  },
  "firestore": {
    "/settings/{settingId}": {
      "schema": "setting",
      "description": "Site global configurations and settings"
    },
    "/articles/{articleId}": {
      "schema": "article",
      "description": "Dynamic articles collection"
    },
    "/activities/{activityId}": {
      "schema": "activity",
      "description": "Past activities and gallery collection"
    },
    "/misi_registrations/{registrationId}": {
      "schema": "misiRegistration",
      "description": "Mission program registrations"
    },
    "/messages/{messageId}": {
      "schema": "message",
      "description": "Contact messages collection"
    }
  }
}
